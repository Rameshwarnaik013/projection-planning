# --- Google Service Account (for writing to your Google Sheet) ---
# From the service account JSON key file:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-robot@your-project.iam.gserviceaccount.com
# Paste the private_key value EXACTLY as in the JSON (keep the \n characters, wrap in double quotes)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# The ID of the Google Sheet you shared with the service account email.
# From the sheet URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# --- Auth ---
# Any long random string. Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
